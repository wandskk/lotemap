# Auth.js / NextAuth (v4 usa NEXTAUTH_URL)
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
ADMIN_EMAIL=devwk.c@gmail.com
# Senha inicial do admin após `npm run prisma:seed` (hash gravado no banco)
ADMIN_PASSWORD=change-me

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lotemap

# Vercel Blob (upload de imagens no admin). Crie um store em vercel.com → Storage → Blob.
# Em desenvolvimento local, use o token Read/Write do painel do Blob.
BLOB_READ_WRITE_TOKEN=

# Opcional: URL publica do site (canonical e Open Graph absolutos). Ex.: https://seudominio.com
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
